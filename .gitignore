# PlatformIO build output and downloaded libraries
.pio/

# VS Code files auto-generated by PlatformIO (machine-specific state)
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# macOS filesystem metadata
.DS_Store
.AppleDouble
.LSOverride
__MACOSX/

# Compiled / linked artifacts (should stay inside .pio, but guard anyway)
*.o
*.a
*.elf
*.bin
*.hex
*.map

# Logs
*.log

# Packet captures
*.pcap
